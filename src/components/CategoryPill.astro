---
import { CATEGORIES, type CategoryKey } from '../config';

interface Props {
  category: CategoryKey;
  class?: string;
}
const { category, class: className = '' } = Astro.props;
const c = CATEGORIES[category];
---
<a
  href={`/category/${c.slug}`}
  class:list={[
    'inline-flex items-center gap-1 rounded-full bg-accent-soft px-3 py-1 text-xs font-bold text-primary transition-opacity hover:opacity-80',
    className,
  ]}
>
  <span aria-hidden="true">{c.emoji}</span>
  {c.label}
</a>

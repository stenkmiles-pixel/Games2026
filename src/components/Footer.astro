---
import { SITE, CATEGORIES, SOCIAL } from '../config';

const year = new Date().getFullYear();
const categories = Object.values(CATEGORIES);
---

<footer class="mt-20 border-t border-line bg-surface-2">
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:px-6 md:grid-cols-4">
    <div class="md:col-span-2">
      <a href="/" class="flex items-center gap-2 text-lg font-semibold text-ink">
        <span aria-hidden="true" class="text-2xl">🏡</span>
        <span class="font-display">{SITE.name}</span>
      </a>
      <p class="mt-3 max-w-sm text-sm leading-relaxed text-ink-muted">{SITE.tagline}</p>
      {
        SOCIAL.length > 0 && (
          <ul class="mt-4 flex flex-wrap gap-3 text-sm">
            {SOCIAL.map((s) => (
              <li>
                <a class="text-primary hover:underline" href={s.href} rel="me noopener" target="_blank">
                  {s.label}
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    <div>
      <h2 class="text-xs font-bold uppercase tracking-wider text-ink-muted">Explore</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-ink hover:text-primary" href="/blog">All Articles</a></li>
        {
          categories.map((c) => (
            <li>
              <a class="text-ink hover:text-primary" href={`/category/${c.slug}`}>
                {c.emoji} {c.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h2 class="text-xs font-bold uppercase tracking-wider text-ink-muted">Site</h2>
      <ul class="mt-3 space-y-2 text-sm">
        <li><a class="text-ink hover:text-primary" href="/about">About</a></li>
        <li><a class="text-ink hover:text-primary" href="/editorial-policy">Editorial Policy</a></li>
        <li><a class="text-ink hover:text-primary" href="/contact">Contact</a></li>
        <li><a class="text-ink hover:text-primary" href="/disclosure">Affiliate Disclosure</a></li>
        <li><a class="text-ink hover:text-primary" href="/privacy">Privacy Policy</a></li>
        <li><a class="text-ink hover:text-primary" href="/rss.xml">RSS Feed</a></li>
      </ul>
    </div>
  </div>

  <div class="border-t border-line">
    <div class="mx-auto max-w-6xl px-4 py-6 text-xs leading-relaxed text-ink-muted sm:px-6">
      <p>
        As an Amazon Associate and affiliate partner, {SITE.name} may earn from qualifying purchases.
        See our <a class="text-primary hover:underline" href="/disclosure">affiliate disclosure</a>.
      </p>
      <p class="mt-2">© {year} {SITE.name}. All trademarks and game names are the property of their respective owners.</p>
    </div>
  </div>
</footer>

---
import { SITE, NAV, CATEGORIES } from '../config';

const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const isActive = (href: string) => {
  const h = href.replace(/\/+$/, '') || '/';
  return h === '/' ? path === '/' : path === h || path.startsWith(h + '/');
};

// Desktop nav: collapse the five category links into one "Browse" dropdown.
const topNav = NAV.filter((i) => !i.href.startsWith('/category/'));
const cats = Object.values(CATEGORIES);
const onCategory = path.startsWith('/category');
---

<header class="sticky top-0 z-40 border-b border-line bg-canvas/85 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
    <a href="/" class="flex items-center gap-2 text-lg font-semibold text-ink">
      <span aria-hidden="true" class="text-2xl">🏡</span>
      <span class="font-display">{SITE.name}</span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 lg:flex">
      {
        topNav.slice(0, 2).map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-full px-3 py-1.5 text-sm font-semibold transition-colors hover:text-primary',
              isActive(item.href) ? 'bg-accent-soft text-primary' : 'text-ink-muted',
            ]}
          >
            {item.label}
          </a>
        ))
      }

      <details data-browse class="group relative">
        <summary
          class:list={[
            'flex cursor-pointer list-none items-center gap-1 rounded-full px-3 py-1.5 text-sm font-semibold transition-colors hover:text-primary [&::-webkit-details-marker]:hidden',
            onCategory ? 'bg-accent-soft text-primary' : 'text-ink-muted',
          ]}
        >
          Browse
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-open:rotate-180"
            aria-hidden="true"
          >
            <path d="m6 9 6 6 6-6" />
          </svg>
        </summary>
        <div
          class="absolute left-0 top-full z-50 mt-2 w-60 rounded-2xl border border-line bg-canvas p-2 shadow-[0_18px_40px_-12px_rgba(60,55,47,0.28)]"
        >
          {
            cats.map((c) => (
              <a
                href={`/category/${c.slug}`}
                class="flex items-center gap-2.5 rounded-lg px-3 py-2 text-sm font-semibold text-ink-muted transition-colors hover:bg-surface-2 hover:text-primary"
              >
                <span aria-hidden="true">{c.emoji}</span> {c.label}
              </a>
            ))
          }
        </div>
      </details>

      {
        topNav.slice(2).map((item) => (
          <a
            href={item.href}
            aria-current={isActive(item.href) ? 'page' : undefined}
            class:list={[
              'rounded-full px-3 py-1.5 text-sm font-semibold transition-colors hover:text-primary',
              isActive(item.href) ? 'bg-accent-soft text-primary' : 'text-ink-muted',
            ]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-1">
      <a
        href="/search"
        aria-label="Search"
        class="rounded-full p-2 text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
      </a>
      <button
        id="theme-toggle"
        type="button"
        aria-label="Toggle dark mode"
        class="rounded-full p-2 text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink"
      >
        <span class="block dark:hidden" aria-hidden="true">🌙</span>
        <span class="hidden dark:block" aria-hidden="true">☀️</span>
      </button>
      <button
        id="menu-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="rounded-full p-2 text-ink-muted transition-colors hover:bg-surface-2 hover:text-ink lg:hidden"
      >
        <span aria-hidden="true">☰</span>
      </button>
    </div>
  </div>

  <nav
    id="mobile-menu"
    aria-label="Mobile"
    hidden
    class="border-t border-line px-4 pb-4 pt-2 lg:hidden"
  >
    {
      NAV.map((item) => (
        <a
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
          class:list={[
            'block rounded-lg px-3 py-2 text-sm font-semibold transition-colors',
            isActive(item.href) ? 'bg-accent-soft text-primary' : 'text-ink-muted hover:bg-surface-2',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </nav>
</header>

<script>
  // Bind on every page load AND after each View Transitions navigation
  // (astro:page-load fires for both), since the header is re-rendered on swap.
  let docListenersBound = false;

  function setupHeader() {
    const themeBtn = document.getElementById('theme-toggle');
    if (themeBtn && !themeBtn.dataset.bound) {
      themeBtn.dataset.bound = 'true';
      themeBtn.addEventListener('click', () => {
        const isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
      });
    }

    const menuBtn = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    if (menuBtn && menu && !menuBtn.dataset.bound) {
      menuBtn.dataset.bound = 'true';
      menuBtn.addEventListener('click', () => {
        const open = menu.hasAttribute('hidden');
        if (open) {
          menu.removeAttribute('hidden');
          menuBtn.setAttribute('aria-expanded', 'true');
        } else {
          menu.setAttribute('hidden', '');
          menuBtn.setAttribute('aria-expanded', 'false');
        }
      });
    }

    // Close the "Browse" dropdown on outside-click or Escape. Bound once at
    // module scope so View Transitions navigations can't stack duplicate
    // listeners; they look the dropdown up fresh on each event.
    if (!docListenersBound) {
      docListenersBound = true;
      const browse = () =>
        document.querySelector('details[data-browse]') as HTMLDetailsElement | null;
      document.addEventListener('click', (e) => {
        const d = browse();
        if (d && d.open && e.target instanceof Node && !d.contains(e.target)) d.open = false;
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
          const d = browse();
          if (d && d.open) d.open = false;
        }
      });
    }
  }

  document.addEventListener('astro:page-load', setupHeader);
</script>

---
interface Props {
  date: Date;
  class?: string;
}
const { date, class: className = '' } = Astro.props;
// Format in UTC so the displayed date always matches the frontmatter date,
// regardless of the build machine's or visitor's timezone.
const label = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
  timeZone: 'UTC',
});
---
<time datetime={date.toISOString()} class={className}>{label}</time>

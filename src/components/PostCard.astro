---
import type { CollectionEntry } from 'astro:content';
import { CATEGORIES } from '../config';
import CategoryPill from './CategoryPill.astro';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const c = CATEGORIES[post.data.category];
const href = `/blog/${post.id}/`;
---
<article
  class:list={[
    'card group flex flex-col overflow-hidden transition-shadow hover:shadow-md',
    featured && 'sm:flex-row',
  ]}
>
  <a
    href={href}
    tabindex="-1"
    aria-hidden="true"
    class:list={[
      'flex items-center justify-center bg-gradient-to-br from-accent-soft to-surface-2 text-5xl sm:text-6xl',
      featured ? 'aspect-video sm:aspect-auto sm:w-2/5' : 'aspect-[16/9]',
    ]}
  >
    <span class="transition-transform duration-300 group-hover:scale-110">{c.emoji}</span>
  </a>
  <div class="flex flex-1 flex-col p-5">
    <CategoryPill category={post.data.category} class="self-start" />
    <h3 class="mt-3 font-display text-lg font-semibold leading-snug text-ink">
      <a href={href} class="transition-colors hover:text-primary">{post.data.title}</a>
    </h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-muted">{post.data.description}</p>
    <p class="mt-4 text-xs text-ink-muted">
      <FormattedDate date={post.data.pubDate} />
    </p>
  </div>
</article>

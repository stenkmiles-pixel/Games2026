---
import type { CollectionEntry } from 'astro:content';
import CategoryPill from './CategoryPill.astro';
import FormattedDate from './FormattedDate.astro';
import SceneHero from './SceneHero.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const href = `/blog/${post.id}/`;
---
<article
  class:list={[
    'card group flex flex-col overflow-hidden transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_18px_36px_-12px_rgba(95,132,112,0.18)]',
    featured && 'sm:flex-row',
  ]}
>
  <a
    href={href}
    tabindex="-1"
    aria-hidden="true"
    transition:name={`hero-${post.id}`}
    class:list={[
      'block overflow-hidden bg-surface-2',
      featured ? 'aspect-video sm:aspect-auto sm:w-2/5' : 'aspect-[16/9]',
    ]}
  >
    {
      post.data.heroImage ? (
        <img
          src={post.data.heroImage}
          alt={post.data.heroImageAlt ?? post.data.title}
          loading="lazy"
          decoding="async"
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      ) : (
        <div class="h-full w-full transition-transform duration-300 group-hover:scale-105">
          <SceneHero seed={post.id} />
        </div>
      )
    }
  </a>
  <div class="flex flex-1 flex-col p-5">
    <CategoryPill category={post.data.category} class="self-start" />
    <h3 class="mt-3 font-display text-lg font-semibold leading-snug text-ink">
      <a href={href} class="transition-colors hover:text-primary">{post.data.title}</a>
    </h3>
    <p class="mt-2 text-sm leading-relaxed text-ink-muted">{post.data.description}</p>
    {
      post.data.editorNote && (
        <p class="mt-3 border-l-2 border-accent pl-3 text-sm italic text-ink-muted">
          {post.data.editorNote}
        </p>
      )
    }
    <p class="mt-auto pt-4 text-xs text-ink-muted">
      <FormattedDate date={post.data.pubDate} />
    </p>
  </div>
</article>

---
interface Props {
  current: number;
  total: number;
}
const { current, total } = Astro.props;
const href = (p: number) => (p === 1 ? '/blog' : `/blog/page/${p}`);
const prev = current > 1 ? current - 1 : null;
const next = current < total ? current + 1 : null;
---
{
  total > 1 && (
    <nav class="mt-12 flex items-center justify-between gap-4" aria-label="Pagination">
      {prev ? (
        <a href={href(prev)} class="btn btn-secondary no-underline">
          ← Newer
        </a>
      ) : (
        <span />
      )}
      <span class="text-sm text-ink-muted">
        Page {current} of {total}
      </span>
      {next ? (
        <a href={href(next)} class="btn btn-secondary no-underline">
          Older →
        </a>
      ) : (
        <span />
      )}
    </nav>
  )
}

---
import type { CollectionEntry } from 'astro:content';
import type { MarkdownHeading } from 'astro';
import { SITE, CATEGORIES } from '../config';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CategoryPill from '../components/CategoryPill.astro';
import FormattedDate from '../components/FormattedDate.astro';
import TableOfContents from '../components/TableOfContents.astro';
import GearBox from '../components/GearBox.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import AdSlot from '../components/AdSlot.astro';
import PostCard from '../components/PostCard.astro';
import SceneHero from '../components/SceneHero.astro';

interface Props {
  post: CollectionEntry<'blog'>;
  headings: MarkdownHeading[];
  related: CollectionEntry<'blog'>[];
}
const { post, headings, related } = Astro.props;
const { title, description, pubDate, updatedDate, category, author, tags, heroImage, heroImageAlt, heroCredit, rating, gameName } = post.data;
const c = CATEGORIES[category];
const canonicalUrl = new URL(`/blog/${post.id}/`, SITE.url).href;

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: { '@type': 'Organization', name: author },
  publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
  mainEntityOfPage: { '@type': 'WebPage', '@id': canonicalUrl },
};

// Editorial Review structured data — only for single-game reviews that set a
// rating. Uses VideoGame (not Product/offers) to stay within Google's guidelines.
const reviewJsonLd =
  category === 'Reviews' && rating != null
    ? {
        '@context': 'https://schema.org',
        '@type': 'Review',
        name: title,
        reviewBody: description,
        datePublished: pubDate.toISOString(),
        author: { '@type': 'Organization', name: author },
        publisher: { '@type': 'Organization', name: SITE.name, url: SITE.url },
        itemReviewed: { '@type': 'VideoGame', name: gameName ?? title },
        reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: 5, worstRating: 1 },
      }
    : null;

const pageJsonLd = reviewJsonLd ? [articleJsonLd, reviewJsonLd] : articleJsonLd;
---
<BaseLayout
  title={title}
  description={description}
  type="article"
  publishedTime={pubDate}
  modifiedTime={updatedDate ?? pubDate}
  jsonLd={pageJsonLd}
>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <Breadcrumbs
      items={[
        { label: 'Home', href: '/' },
        { label: c.label, href: `/category/${c.slug}` },
        { label: title },
      ]}
    />

    <div class="mt-8 grid gap-10 lg:grid-cols-[minmax(0,1fr)_18rem]">
      <article>
        <header>
          <CategoryPill category={category} />
          <h1 class="mt-4 font-display text-3xl font-bold leading-tight text-ink sm:text-4xl">
            {title}
          </h1>
          <p class="mt-3 text-lg leading-relaxed text-ink-muted">{description}</p>
          <div class="mt-4 flex flex-wrap items-center gap-x-3 gap-y-1 text-sm text-ink-muted">
            <span>By {author}</span>
            <span aria-hidden="true">·</span>
            <FormattedDate date={pubDate} />
            {
              updatedDate && (
                <>
                  <span aria-hidden="true">·</span>
                  <span>
                    Updated <FormattedDate date={updatedDate} />
                  </span>
                </>
              )
            }
          </div>
          {
            rating != null && (
              <p class="mt-4 inline-flex items-center gap-1.5 rounded-full bg-accent-soft px-3 py-1 text-sm font-bold text-primary">
                <span aria-hidden="true">☕</span>
                <span>{rating} / 5</span>
                <span class="sr-only">Our cozy score: {rating} out of 5</span>
              </p>
            )
          }
        </header>

        <figure transition:name={`hero-${post.id}`} class="mt-6 overflow-hidden rounded-2xl border border-line bg-surface-2">
          <div class="aspect-[16/9] w-full">
            {
              heroImage ? (
                <img src={heroImage} alt={heroImageAlt ?? title} class="h-full w-full object-cover" />
              ) : (
                <SceneHero seed={post.id} />
              )
            }
          </div>
          {heroCredit && <figcaption class="px-4 py-2 text-xs text-ink-muted">{heroCredit}</figcaption>}
        </figure>

        <AdSlot />

        <div class="prose prose-lg mt-6 max-w-none">
          <slot />
        </div>

        {
          tags.length > 0 && (
            <div class="mt-10 flex flex-wrap gap-2">
              {tags.map((t) => (
                <span class="rounded-full bg-surface-2 px-3 py-1 text-xs text-ink-muted">#{t}</span>
              ))}
            </div>
          )
        }

        <AdSlot />
        <NewsletterCTA class="mt-10" />
      </article>

      <aside class="space-y-6 lg:sticky lg:top-24 lg:self-start">
        <TableOfContents headings={headings} />
        <DownloadCTA />
        <GearBox />
      </aside>
    </div>

    {
      related.length > 0 && (
        <section class="mt-16">
          <h2 class="font-display text-2xl font-semibold text-ink">More cozy reads</h2>
          <div class="mt-6 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
            {related.map((p) => (
              <PostCard post={p} />
            ))}
          </div>
        </section>
      )
    }
  </div>
</BaseLayout>

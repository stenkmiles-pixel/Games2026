---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import PostGrid from '../../../components/PostGrid.astro';
import Pagination from '../../../components/Pagination.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { getPublishedPosts, PAGE_SIZE } from '../../../utils/posts';

export async function getStaticPaths() {
  const posts = await getPublishedPosts();
  const total = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
  const paths = [];
  // Page 1 lives at /blog, so only generate 2..total here.
  for (let p = 2; p <= total; p++) {
    paths.push({ params: { page: String(p) }, props: { pageNum: p, total } });
  }
  return paths;
}

const { pageNum, total } = Astro.props;
const posts = await getPublishedPosts();
const start = (pageNum - 1) * PAGE_SIZE;
const pagePosts = posts.slice(start, start + PAGE_SIZE);
---
<BaseLayout
  title={`All Articles — Page ${pageNum}`}
  description="Browse more cozy & simulation game articles on Sleepy Harbor."
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'All Articles', href: '/blog' }, { label: `Page ${pageNum}` }]} />
    <h1 class="mt-6 font-display text-3xl font-bold text-ink sm:text-4xl">All Articles</h1>
    <p class="mt-2 max-w-2xl text-ink-muted">Page {pageNum} of {total}.</p>
    <PostGrid posts={pagePosts} class="mt-8" />
    <Pagination current={pageNum} total={total} />
  </div>
</BaseLayout>

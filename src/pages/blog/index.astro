---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostGrid from '../../components/PostGrid.astro';
import Pagination from '../../components/Pagination.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { getPublishedPosts, PAGE_SIZE } from '../../utils/posts';

const posts = await getPublishedPosts();
const total = Math.max(1, Math.ceil(posts.length / PAGE_SIZE));
const pagePosts = posts.slice(0, PAGE_SIZE);
---
<BaseLayout
  title="All Articles"
  description="Every cozy & simulation game recommendation, review, guide and resource round-up on Cozy Game Guide."
>
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'All Articles' }]} />
    <h1 class="mt-6 font-display text-3xl font-bold text-ink sm:text-4xl">All Articles</h1>
    <p class="mt-2 max-w-2xl text-ink-muted">
      Recommendations, reviews, guides and resources for cozy &amp; simulation games — newest first.
    </p>
    <PostGrid posts={pagePosts} class="mt-8" />
    <Pagination current={1} total={total} />
  </div>
</BaseLayout>

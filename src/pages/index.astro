---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostGrid from '../components/PostGrid.astro';
import PostCard from '../components/PostCard.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import AdSlot from '../components/AdSlot.astro';
import { SITE, CATEGORIES } from '../config';
import { getPublishedPosts } from '../utils/posts';

const posts = await getPublishedPosts();
const featured = posts.find((p) => p.data.featured) ?? posts[0];
const latest = posts.filter((p) => p.id !== featured?.id).slice(0, 6);
const categories = Object.values(CATEGORIES);
---
<BaseLayout title={SITE.title} description={SITE.description}>
  <section class="relative overflow-hidden border-b border-line bg-gradient-to-b from-accent-soft to-canvas">
    <div class="relative z-10 mx-auto max-w-4xl px-4 pb-36 pt-16 text-center sm:px-6 sm:pb-48 sm:pt-24">
      <p class="text-sm font-bold uppercase tracking-widest text-primary">Cozy &amp; simulation games</p>
      <h1 class="mt-4 font-display text-4xl font-bold leading-tight text-ink sm:text-5xl">
        Find your next game to unwind with.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-ink-muted">{SITE.tagline}</p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/blog" class="btn btn-primary no-underline">Browse all articles</a>
        <a href="/category/recommendations" class="btn btn-secondary no-underline">Game recommendations</a>
      </div>
    </div>

    <!-- Decorative "cozy valley" — original SVG, no licensed art. -->
    <svg
      class="pointer-events-none absolute inset-x-0 bottom-0 h-36 w-full sm:h-48"
      viewBox="0 0 1200 200"
      preserveAspectRatio="xMidYMax slice"
      xmlns="http://www.w3.org/2000/svg"
      aria-hidden="true"
    >
      <circle cx="1052" cy="56" r="28" fill="#f0c473" opacity="0.8" />
      <path d="M0,128 Q300,92 620,124 T1200,114 L1200,200 L0,200 Z" fill="#9ec3ab" opacity="0.9" />
      <path d="M468,168 L490,126 L512,168 Z" fill="#4c6c5a" />
      <path d="M700,168 L726,116 L752,168 Z" fill="#4c6c5a" />
      <path d="M556,168 L556,118 L600,88 L644,118 L644,168 Z" fill="#5f8470" />
      <rect x="629" y="106" width="11" height="18" fill="#5f8470" />
      <rect x="590" y="128" width="20" height="20" rx="3" fill="#f4c879" opacity="0.95" />
      <path d="M0,158 Q360,120 700,156 T1200,146 L1200,200 L0,200 Z" fill="#4c6c5a" />
    </svg>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    {
      featured && (
        <section>
          <h2 class="flex items-center gap-2 font-display text-2xl font-semibold text-ink">
            <span aria-hidden="true" class="text-primary">✦</span> Editor's pick
          </h2>
          <div class="mt-6">
            <PostCard post={featured} featured />
          </div>
        </section>
      )
    }
  </div>

  <section class="border-y border-line bg-surface-2">
    <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
      <h2 class="font-display text-2xl font-semibold text-ink">Browse by type</h2>
      <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          categories.map((c) => (
            <a href={`/category/${c.slug}`} class="card group bg-surface p-6 transition-shadow hover:shadow-md">
              <div class="text-4xl">{c.emoji}</div>
              <h3 class="mt-3 font-display text-lg font-semibold text-ink transition-colors group-hover:text-primary">
                {c.label}
              </h3>
              <p class="mt-1 text-sm leading-relaxed text-ink-muted">{c.blurb}</p>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6">
    <AdSlot />

    <section>
      <div class="flex items-baseline justify-between gap-4">
        <h2 class="font-display text-2xl font-semibold text-ink">Latest articles</h2>
        <a href="/blog" class="shrink-0 text-sm font-semibold text-primary hover:underline">View all →</a>
      </div>
      <PostGrid posts={latest} class="mt-6" />
    </section>

    <NewsletterCTA class="mt-16" />
  </div>
</BaseLayout>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
---
<BaseLayout
  title="Contact"
  description={`Get in touch with the ${SITE.name} team — feedback, corrections, suggestions and partnership enquiries.`}
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
    <article class="prose prose-lg mt-6 max-w-none">
      <h1>Contact us</h1>
      <p>
        We'd genuinely love to hear from you — whether it's a game we should cover, a correction,
        a question about a guide, or a partnership enquiry.
      </p>
      <p>
        The best way to reach us is by email:
      </p>
      <p>
        <a class="btn btn-primary no-underline" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </p>
      <p>We read everything and try to reply within a few days. Thanks for stopping by! 🌿</p>
    </article>
  </div>
</BaseLayout>

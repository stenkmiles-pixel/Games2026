---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE, CATEGORIES } from '../config';

const cats = Object.entries(CATEGORIES).map(([key, c]) => ({ key, label: c.label }));
const chipOn = 'rounded-full border border-line bg-primary px-3 py-1.5 text-sm font-semibold text-white';
const chipOff =
  'rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-semibold text-ink-muted transition-colors hover:text-primary';
---
<BaseLayout
  title={`Search · ${SITE.name}`}
  description="Search cozy game recommendations, reviews and guides — or filter by type — across Cozy Game Guide."
>
  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6">
    <h1 class="font-display text-3xl font-bold text-ink sm:text-4xl">Search</h1>
    <p class="mt-2 text-ink-muted">Find a game, guide or list — search, or filter by type.</p>

    <div class="mt-6">
      <label class="sr-only" for="site-search">Search articles</label>
      <input
        id="site-search"
        type="search"
        autocomplete="off"
        autofocus
        placeholder="Try “stardew”, “steam deck”, “fishing”…"
        class="w-full rounded-full border border-line bg-surface px-5 py-3 text-ink placeholder:text-ink-muted focus:border-primary focus:outline-none"
      />
    </div>

    <div class="mt-4 flex flex-wrap gap-2" data-cat-filters>
      <button data-cat="" class={chipOn} aria-pressed="true">All</button>
      {cats.map((c) => <button data-cat={c.key} class={chipOff} aria-pressed="false">{c.label}</button>)}
    </div>

    <p id="search-status" class="mt-5 text-sm text-ink-muted" aria-live="polite"></p>
    <ul id="search-results" class="mt-3 space-y-3"></ul>
  </div>
</BaseLayout>

<script>
  function setupSearch() {
    const input = document.getElementById('site-search') as HTMLInputElement | null;
    if (!input || input.dataset.bound) return;
    input.dataset.bound = 'true';

    const results = document.getElementById('search-results');
    const status = document.getElementById('search-status');
    const filters = document.querySelector('[data-cat-filters]');
    let index: Array<{ title: string; description: string; url: string; category: string; tags: string[] }> = [];
    let ready = false;
    let activeCat = '';
    const ON = 'rounded-full border border-line bg-primary px-3 py-1.5 text-sm font-semibold text-white';
    const OFF =
      'rounded-full border border-line bg-surface px-3 py-1.5 text-sm font-semibold text-ink-muted transition-colors hover:text-primary';

    const esc = (s: string) =>
      s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] as string);

    function render() {
      if (!ready || !results || !status) return;
      const raw = input!.value.trim();
      const words = raw ? raw.toLowerCase().split(/\s+/) : [];
      if (!raw && !activeCat) {
        results.innerHTML = '';
        status.textContent = '';
        return;
      }
      const hits = index.filter((it) => {
        if (activeCat && it.category !== activeCat) return false;
        if (!words.length) return true;
        const hay = (it.title + ' ' + it.description + ' ' + it.category + ' ' + it.tags.join(' ')).toLowerCase();
        return words.every((w) => hay.includes(w));
      });
      const inCat = activeCat ? ` in ${activeCat}` : '';
      status.textContent = raw
        ? `${hits.length} result${hits.length === 1 ? '' : 's'} for “${raw}”${inCat}`
        : `${hits.length} article${hits.length === 1 ? '' : 's'}${inCat}`;
      results.innerHTML = hits
        .slice(0, 60)
        .map(
          (it) => `
        <li class="card p-4">
          <div class="flex items-start justify-between gap-3">
            <a class="font-display text-lg font-semibold text-ink hover:text-primary" href="${it.url}">${esc(it.title)}</a>
            <span class="shrink-0 rounded-full bg-surface-2 px-2 py-0.5 text-xs text-ink-muted">${esc(it.category)}</span>
          </div>
          <p class="mt-1 text-sm leading-relaxed text-ink-muted">${esc(it.description)}</p>
        </li>`
        )
        .join('');
    }

    filters?.querySelectorAll('button[data-cat]').forEach((btn) => {
      btn.addEventListener('click', () => {
        activeCat = (btn as HTMLElement).dataset.cat || '';
        filters.querySelectorAll('button[data-cat]').forEach((b) => {
          const on = b === btn;
          b.setAttribute('aria-pressed', String(on));
          b.className = on ? ON : OFF;
        });
        render();
      });
    });

    fetch('/search-index.json')
      .then((r) => r.json())
      .then((data) => {
        index = data;
        ready = true;
        const q = new URLSearchParams(location.search).get('q');
        if (q) input.value = q;
        render();
      })
      .catch(() => {
        if (status) status.textContent = 'Search is unavailable right now.';
      });

    input.addEventListener('input', render);
  }

  document.addEventListener('astro:page-load', setupSearch);
</script>

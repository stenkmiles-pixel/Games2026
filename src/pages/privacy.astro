---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../config';
---
<BaseLayout
  title="Privacy Policy"
  description={`How ${SITE.name} handles data, cookies and advertising.`}
>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
    <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Privacy Policy' }]} />
    <article class="prose prose-lg mt-6 max-w-none">
      <h1>Privacy Policy</h1>
      <p><em>Last updated: May 2026</em></p>
      <p>
        This Privacy Policy explains how {SITE.name} ("we", "us") handles information when you visit
        this website. We aim to collect as little as possible.
      </p>

      <h2>Information we collect</h2>
      <p>
        We do not require you to create an account, and we do not ask for personal information to
        read the site. If you choose to email us or subscribe to our newsletter, we will receive the
        information you provide (such as your email address) and use it only to reply or to send the
        updates you asked for.
      </p>

      <h2>Cookies &amp; analytics</h2>
      <p>
        We may use privacy-friendly analytics to understand which articles are useful, in aggregate.
        Some third-party services we use (such as advertising or affiliate partners) may set cookies
        in your browser. You can control or delete cookies through your browser settings at any time.
      </p>

      <h2>Advertising</h2>
      <p>
        We may display ads served by third-party networks (for example, Google AdSense). These
        partners may use cookies and similar technologies to serve ads based on your prior visits to
        this and other websites. You can learn about and opt out of personalized advertising via
        Google's <a href="https://adssettings.google.com" rel="noopener" target="_blank">Ads Settings</a>.
      </p>

      <h2>Affiliate links</h2>
      <p>
        Some links are affiliate links. When you click them, the partner may know you came from our
        site so any resulting purchase is attributed correctly. See our
        <a href="/disclosure">affiliate disclosure</a> for details.
      </p>

      <h2>Children</h2>
      <p>This site is intended for a general audience and is not directed at children under 13.</p>

      <h2>Changes</h2>
      <p>
        We may update this policy from time to time. The "last updated" date above will always
        reflect the latest version.
      </p>

      <h2>Contact</h2>
      <p>Questions about your privacy? Email us at <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.</p>
    </article>
  </div>
</BaseLayout>
